    {
      "id": "EEcTRK_HDDNtaG9d4hpgD",
      "type": "text",
      "x": -2454.5574968126084,
      "y": -176.90877999199756,
      "width": 604.9992065429688,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
