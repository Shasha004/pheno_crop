    {
      "id": "GLmutalXi_WJijmjMtRk4",
      "type": "text",
      "x": -4712.033592967572,
      "y": 1348.2381180075927,
      "width": 537.8831787109375,
      "height": 177.9148500587486,
      "angle": 6.282992299509285,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "dotted",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b01",
      "roundness": null,
      "seed": 1268271467,
      "version": 549,
      "versionNonce": 2128280267,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775334275199,
      "link": null,
      "locked": false,
      "text": "Here are the printable ASCII characters from ' ' to '~'\n\n     0123456789ABCDEF0123456789ABCDEF\n    +--------------------------------\n0x20| !\"#$%&'()*+,-./0123456789:;<=>?\n0x40|@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_\n0x60|`abcdefghijklmnopqrstuvwxyz{|}~\n",
      "fontSize": 17.79148500587486,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Here are the printable ASCII characters from ' ' to '~'\n\n     0123456789ABCDEF0123456789ABCDEF\n    +--------------------------------\n0x20| !\"#$%&'()*+,-./0123456789:;<=>?\n0x40|@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_\n0x60|`abcdefghijklmnopqrstuvwxyz{|}~\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "VtxpqmsmX6Af3QIM4WeR7",
      "type": "text",
      "x": -1368.4908555955521,
      "y": 1885.5611825251212,
      "width": 912.9988403320312,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "dotted",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b02",
      "roundness": null,
      "seed": 323796844,
      "version": 585,
      "versionNonce": 746531685,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775334275199,
      "link": null,
      "locked": false,
      "text": "APM [Advanced Power Management]: \n\n- It is a power management standard, developed by intel and microsoft, \nwhich allows the OS to control the amount of power sent to the devices.\n\nACPI [Advanced Configuration and Power Interface]: \n\n- It is a Power Management and configuration standard for the PC, \ndeveloped by Intel, Microsoft and Toshiba. \n\n- ACPI allows the operating system to control the amount of power each device \nis given (allowing it to put certain devices on standby or power-off for example). \n\n- It is also used to control and/or check thermal zones \n(temperature sensors, fan speeds, etc), battery levels, PCI IRQ routing, \nCPUs, NUMA domains and many other things.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "APM [Advanced Power Management]: \n\n- It is a power management standard, developed by intel and microsoft, \nwhich allows the OS to control the amount of power sent to the devices.\n\nACPI [Advanced Configuration and Power Interface]: \n\n- It is a Power Management and configuration standard for the PC, \ndeveloped by Intel, Microsoft and Toshiba. \n\n- ACPI allows the operating system to control the amount of power each device \nis given (allowing it to put certain devices on standby or power-off for example). \n\n- It is also used to control and/or check thermal zones \n(temperature sensors, fan speeds, etc), battery levels, PCI IRQ routing, \nCPUs, NUMA domains and many other things.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "vNFVBEpZwp-7jFCHy4OHP",
      "type": "text",
      "x": -1387.6006553022817,
      "y": 2400.4210324579603,
      "width": 1396.9984130859375,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "dotted",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b04",
      "roundness": null,
      "seed": 1247934572,
      "version": 96,
      "versionNonce": 1055353195,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775334275199,
      "link": null,
      "locked": false,
      "text": "Serial Ports:\n\nA serial port is a serial communication interface through which information transfers in or out sequentially one bit at a time.\nThis is in contrast to a parallel port, which communicates multiple bits simultaneously in parallel.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Serial Ports:\n\nA serial port is a serial communication interface through which information transfers in or out sequentially one bit at a time.\nThis is in contrast to a parallel port, which communicates multiple bits simultaneously in parallel.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "K9o6moX4Qx109HdaNlvxm",
      "type": "rectangle",
      "x": -1415.3018472083338,
      "y": 2374.1776884260903,
      "width": 1452.1318899695723,
      "height": 150.17026420199542,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 2,
      "opacity": 100,
