    {
      "id": "827i2gF00-Hvr-3tA-VvJ",
      "type": "text",
      "x": -5314.243139605969,
      "y": 1022.1120153376125,
      "width": 472.9993896484375,
      "height": 150,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0h",
      "roundness": null,
      "seed": 1627840803,
      "version": 364,
      "versionNonce": 1443501893,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1775334275199,
      "link": null,
      "locked": false,
      "text": "The x86-interrupt calling convention\nguarantees us that all the registers are\npreserved when a function is called and \nthey are all returned their original state \nwhen the function returns ... this is for\nwhen exceptions occur ..",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The x86-interrupt calling convention\nguarantees us that all the registers are\npreserved when a function is called and \nthey are all returned their original state \nwhen the function returns ... this is for\nwhen exceptions occur ..",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "un_6CLGTM1hL2wGe_G6IW",
      "type": "rectangle",
      "x": -5331.949783015487,
      "y": 1006.618679557675,
      "width": 489.1462445551524,
      "height": 188.13318501143408,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
